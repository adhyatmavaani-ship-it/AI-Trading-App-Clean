# Copy to /etc/quentrader/quentrader.env and fill secrets on the VPS.
# Keep live exchange credentials empty unless you have completed a separate live-trading deployment audit.

SERVICE_NAME=quentrader
ENVIRONMENT=prod
TRADING_MODE=paper
DEBUG_ROUTES_ENABLED=false
LOG_LEVEL=INFO
JSON_LOGS=true

PUBLIC_BASE_URL=https://quentrader.com
# Leave CORS_ALLOWED_ORIGINS unset in systemd; prod falls back to PUBLIC_BASE_URL.
# Set it only through a tested process environment if multiple browser origins are required.
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOW_WILDCARD_NON_PROD=false

HOST=127.0.0.1
PORT=8000

# Authentication: prod requires at least one configured API key or Firestore auth source.
# install.sh replaces [] with a generated first-run key when creating /etc/quentrader/quentrader.env.
AUTH_API_KEYS_JSON='[]'
AUTH_CACHE_TTL_SECONDS=300

# Storage and cache. Redis is optional; the backend can degrade to in-memory cache when not configured.
REDIS_URL=
FIRESTORE_PROJECT_ID=
GOOGLE_CREDENTIALS_JSON=
GOOGLE_APPLICATION_CREDENTIALS=
PRO_STORAGE_PATH=app_data/sandbox.db
MODEL_DIR=artifacts
TRAINING_BUFFER_PATH=artifacts/training_buffer.sqlite3

# Conservative broker/exchange defaults for paper mode.
PRIMARY_EXCHANGE=kraken
BACKUP_EXCHANGES='["coinbase","binance"]'
BINANCE_TESTNET=false
BINANCE_API_KEY=
BINANCE_API_SECRET=
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_API_PASSPHRASE=

# Startup and execution safety controls. These preserve existing behavior; they do not enable autonomy.
FORCE_EXECUTION_OVERRIDE_ENABLED=false
EXECUTION_CIRCUIT_BREAKER_ENABLED=true
EXECUTION_CIRCUIT_BREAKER_BLOCK_PAPER=false
EXECUTION_EVENT_DISPATCHER_ENABLED=true
BROKER_RECONCILIATION_ENABLED=true
BROKER_STATE_SYNC_ENABLED=true
STARTUP_TASK_TIMEOUT_SECONDS=5
EXECUTION_SHARD_COUNT=64
EXECUTION_QUEUE_BATCH_SIZE=250
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_PER_HOUR=2000

# Optional outbound integrations.
ALERT_WEBHOOK_URL=
SECRET_MANAGER_PROJECT_ID=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=black-swan-intel
